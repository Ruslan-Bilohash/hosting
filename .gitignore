# Secrets & production data (never commit)
/data/*.json
/data/logs/
/data/db.config.php
/data/admin.config.php
/data/mysql-provision.config.php
/data/ssh.config.local.php
/data/pma.config.php
/data/installed.lock

# Local overrides (SSH, server IP, deploy paths)
/config.local.php
/scripts/deploy.config.local.ps1

# Client site files — created at runtime by installer/seed
/public_html/*
!/public_html/.htaccess

# Internal ops scripts (read production configs over SSH)
/scripts/ssh-*.ps1
/scripts/deploy-to-ilove.ps1
/scripts/setup-shared-mysql.php
/scripts/write-provision-from-dbconfig.php
/scripts/test-provision.php

# Keep examples & static seed data
!/data/*.example.php
!/data/countries.json

# phpMyAdmin vendor (install via scripts/install-phpmyadmin.ps1)
/pma/vendor/
/pma/js/
/pma/templates/

# OS & IDE
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*~

# Deploy temp
_hosting-deploy.zip
/release-payload.json

# Source screenshots (WebP gallery in docs/screenshots/)
/screenshot/
/scripts/node_modules/
/dist/