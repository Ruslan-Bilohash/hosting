# Super-admin — HTTPS only, no cache, no indexing
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTPS} !=on
  RewriteCond %{HTTP:X-Forwarded-Proto} !https [NC]
  RewriteCond %{HTTP:X-Forwarded-SSL} !on [NC]
  RewriteCond %{HTTP:X-Https} !1 [NC]
  RewriteCond %{HTTP:CF-Visitor} !"scheme":"https" [NC]
  RewriteCond %{SERVER_PORT} !443
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>
<IfModule LiteSpeed>
  CacheDisable public /
</IfModule>
<IfModule mod_headers.c>
  Header always set X-Robots-Tag "noindex, nofollow, noarchive"
  Header always set Cache-Control "no-store, no-cache, must-revalidate, private, max-age=0"
  Header always set Pragma "no-cache"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains" env=HTTPS
  Header always set Content-Security-Policy "upgrade-insecure-requests" env=HTTPS
</IfModule>
<FilesMatch "\.(env|ini|log|sql|bak|old|dist)$">
  Require all denied
</FilesMatch>