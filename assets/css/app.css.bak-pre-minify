:root {
  /* Soft emerald green brand */
  --hs-bg: #f3faf6;
  --hs-surface: #ffffff;
  --hs-border: #d8ebe2;
  --hs-text: #0f1f17;
  --hs-muted: #5b6f66;
  --hs-accent: #059669;
  --hs-accent-2: #34d399;
  --hs-accent-soft: #ecfdf5;
  --hs-btn-from: #10b981;
  --hs-btn-to: #047857;
  --hs-success: #059669;
  --hs-danger: #dc2626;
  --hs-radius: 14px;
  --hs-shadow: 0 12px 40px rgba(5, 150, 105, 0.08);
  --hs-sidebar: 260px;
  --font: "DM Sans", system-ui, -apple-system, sans-serif;
}

*, *::before, *::after { box-sizing: border-box; }
.hidden { display: none !important; }
.hs-visually-hidden {
  position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
  overflow: hidden; clip-path: inset(50%); white-space: nowrap; border: 0;
}
html {
  scroll-behavior: smooth;
  overflow-x: clip;
  -webkit-text-size-adjust: 100%;
}
body {
  margin: 0;
  font-family: var(--font);
  background: var(--hs-bg);
  color: var(--hs-text);
  line-height: 1.5;
  -webkit-font-smoothing: antialiased;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  overflow-x: clip;
  padding-left: env(safe-area-inset-left);
  padding-right: env(safe-area-inset-right);
}
img, svg, video, canvas { max-width: 100%; height: auto; }

a { color: var(--hs-accent); text-decoration: none; }
a:hover { text-decoration: underline; }

.hs-gradient-text {
  background: linear-gradient(120deg, var(--hs-accent), var(--hs-accent-2));
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
}

/* ——— Public ——— */
.hs-demo-banner {
  display: flex; align-items: center; justify-content: center; gap: .5rem; flex-wrap: wrap;
  padding: .55rem 1rem; text-align: center; font-size: .82rem; font-weight: 600;
  background: linear-gradient(90deg, #fef3c7, #fde68a);
  color: #92400e; border-bottom: 1px solid #fcd34d;
}
.hs-demo-banner i { opacity: .85; }
.hs-dev-banner {
  display: flex; align-items: center; justify-content: center; gap: .55rem; flex-wrap: wrap;
  padding: .65rem 1.25rem; text-align: center; font-size: .88rem; font-weight: 700;
  letter-spacing: .01em;
  background: linear-gradient(90deg, #ea580c 0%, #f97316 45%, #059669 100%);
  color: #fff; border-bottom: 1px solid #c2410c;
  box-shadow: 0 1px 0 rgba(0, 0, 0, .06);
}
.hs-dev-banner i { font-size: .95rem; opacity: .95; }
.hs-skip-link {
  position: absolute; left: -9999px; top: auto; width: 1px; height: 1px; overflow: hidden;
}
.hs-skip-link:focus {
  position: fixed; left: .75rem; top: .75rem; z-index: 9999; width: auto; height: auto;
  padding: .55rem .9rem; background: #0f172a; color: #f8fafc; border-radius: 8px;
  font-weight: 600; text-decoration: none;
}
.hs-sr-only {
  position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
  overflow: hidden; clip: rect(0, 0, 0, 0); white-space: nowrap; border: 0;
}
.hs-hero-card-label { margin: 0 0 .5rem; font-size: .75rem; font-weight: 600; }
.hs-hero-card--login {
  display: flex;
  flex-direction: column;
  gap: .35rem;
}
.hs-hero-card--login .hs-hero-card-label {
  display: flex;
  align-items: center;
  gap: .4rem;
  font-size: .82rem;
  color: var(--hs-muted);
  margin-bottom: .65rem;
}
.hs-hero-login-form .hs-field { margin-bottom: .75rem; }
.hs-hero-login-form .hs-field label {
  font-size: .72rem;
  margin-bottom: .28rem;
}
.hs-hero-login-form .hs-field input {
  width: 100%;
  padding: .55rem .7rem;
  font-size: .9rem;
}
.hs-hero-login-submit {
  width: 100%;
  margin-top: .15rem;
  justify-content: center;
}
.hs-hero-login-hint,
.hs-hero-login-demo {
  margin: .55rem 0 0;
  font-size: .72rem;
  color: var(--hs-muted);
  text-align: center;
  line-height: 1.45;
}
.hs-hero-login-demo code {
  font-size: .78rem;
  padding: .12rem .35rem;
  border-radius: 6px;
  background: color-mix(in srgb, var(--hs-accent) 10%, var(--hs-surface));
}
.hs-hero-login-footer {
  margin: .85rem 0 0;
  padding-top: .75rem;
  border-top: 1px solid var(--hs-border);
  font-size: .78rem;
  text-align: center;
  color: var(--hs-muted);
}
.hs-hero-login-footer a { font-weight: 600; }
.hs-hero--cabinet .hs-hero-kicker i { color: var(--hs-accent); }
.hs-nav-link {
  font-size: .85rem; font-weight: 600; color: var(--hs-muted); text-decoration: none; padding: .35rem .15rem;
}
.hs-nav-link:hover { color: var(--hs-accent); text-decoration: none; }
/* ——— Public site header (trust bar + nav) ——— */
.hs-site-header {
  position: sticky; top: 0; z-index: 200;
  background: rgba(255, 255, 255, .92);
  backdrop-filter: blur(10px);
  border-bottom: 1px solid var(--hs-border);
  box-shadow: 0 1px 0 rgba(15, 23, 42, .04);
  transition: box-shadow .2s ease, background .2s ease;
}
.hs-site-header.is-scrolled {
  background: rgba(255, 255, 255, .98);
  box-shadow: 0 4px 24px rgba(15, 23, 42, .08);
}
.hs-header-trust {
  background: linear-gradient(90deg, #0f172a 0%, #1e293b 100%);
  color: #cbd5e1; font-size: .72rem; font-weight: 500;
  border-bottom: 1px solid rgba(148, 163, 184, .15);
}
.hs-header-trust-inner {
  max-width: 1200px; margin: 0 auto; padding: .4rem 1.5rem;
  display: flex; flex-wrap: wrap; align-items: center; justify-content: center; gap: .65rem 1.25rem;
}
.hs-header-trust-item {
  display: inline-flex; align-items: center; gap: .35rem; white-space: nowrap;
}
.hs-header-trust-link {
  color: inherit; text-decoration: none; transition: color .15s ease;
}
.hs-header-trust-link:hover { color: #f8fafc; text-decoration: underline; text-underline-offset: 2px; }
.hs-header-trust-item i { color: #34d399; font-size: .7rem; }
.hs-header-main { padding: 0; }
.hs-header-main-inner {
  max-width: 1200px; margin: 0 auto; padding: .75rem 1.5rem;
  display: grid; grid-template-columns: auto 1fr auto; align-items: center; gap: 1rem 1.25rem;
}
.hs-logo-text { white-space: nowrap; }
.hs-header-nav {
  display: flex; align-items: center; justify-content: center; flex-wrap: wrap; gap: .25rem .15rem;
}
.hs-header-nav-link {
  display: inline-flex; align-items: center; gap: .4rem;
  padding: .5rem .85rem; border-radius: 999px;
  font-size: .88rem; font-weight: 600; color: #334155; text-decoration: none;
  transition: color .15s, background .15s;
}
.hs-header-nav-link i { font-size: .82rem; color: var(--hs-muted); transition: color .15s; }
.hs-header-nav-link:hover,
.hs-header-nav-link.is-active {
  color: var(--hs-accent); background: var(--hs-accent-soft); text-decoration: none;
}
.hs-header-nav-link:hover i,
.hs-header-nav-link.is-active i { color: var(--hs-accent); }
.hs-header-actions {
  display: flex; align-items: center; justify-content: flex-end; flex-wrap: wrap; gap: .45rem;
}
.hs-header-btn-login { padding: .5rem .9rem; font-size: .85rem; }
.hs-header-burger {
  display: none; align-items: center; justify-content: center;
  width: 2.5rem; height: 2.5rem; border: 1px solid var(--hs-border); border-radius: 10px;
  background: var(--hs-surface); color: var(--hs-text); cursor: pointer;
}
.hs-header-mobile-backdrop {
  position: fixed; inset: 0; background: rgba(15, 23, 42, .45); z-index: 199;
}
.hs-header-mobile-backdrop[hidden] { display: none; }
@media (max-width: 960px) {
  /* Phone/tablet: logo (icon only) · Get started · burger */
  .hs-header-main-inner {
    grid-template-columns: minmax(0, 1fr) auto auto;
    grid-template-areas: "logo actions burger";
  }
  .hs-logo { grid-area: logo; min-width: 0; }
  .hs-logo-text { display: none; } /* icon-only brand on mobile */
  .hs-header-burger { display: inline-flex; grid-area: burger; flex-shrink: 0; }
  .hs-header-actions { grid-area: actions; flex-shrink: 0; min-width: 0; }
  .hs-header-actions .hs-header-btn-login { display: none; }
  .hs-header-actions .hs-btn-primary { padding: .5rem .85rem; font-size: .82rem; }
  .hs-header-actions .hp-lang-btn span:nth-child(2) { display: none; }
  .hs-header-nav {
    position: fixed; top: 0; right: 0; z-index: 201;
    width: min(18rem, 88vw); height: 100vh; height: 100dvh;
    flex-direction: column; align-items: stretch; justify-content: flex-start;
    gap: .35rem; padding: 4.5rem 1rem 1.5rem;
    background: #fff; border-left: 1px solid var(--hs-border);
    box-shadow: -8px 0 32px rgba(15, 23, 42, .12);
    transform: translateX(100%); transition: transform .22s ease;
    overflow-y: auto;
  }
  .hs-site-header.is-nav-open .hs-header-nav { transform: translateX(0); }
  .hs-site-header.is-nav-open .hs-header-mobile-backdrop { display: block; }
  .hs-header-nav-link { border-radius: 12px; padding: .75rem 1rem; font-size: .95rem; }
  .hs-header-nav-mobile-actions {
    display: flex; flex-direction: column; gap: .5rem;
    margin-top: auto; padding-top: 1rem; border-top: 1px solid var(--hs-border);
  }
  .hs-header-nav-mobile-actions .hs-btn { width: 100%; justify-content: center; }
}
@media (min-width: 961px) {
  .hs-header-nav-mobile-actions { display: none; }
}
@media (max-width: 520px) {
  .hs-header-trust-inner {
    justify-content: flex-start; padding: .35rem 1rem; gap: .5rem .85rem;
    overflow-x: auto; -webkit-overflow-scrolling: touch; flex-wrap: nowrap;
    scrollbar-width: none;
  }
  .hs-header-trust-inner::-webkit-scrollbar { display: none; }
  .hs-header-trust-item { flex-shrink: 0; white-space: nowrap; }
  .hs-header-main-inner { padding: .65rem 1rem; gap: .5rem; }
  .hs-header-actions .hp-lang-btn span:nth-child(2) { display: none; }
  .hs-header-actions .hs-header-btn-register { padding: .5rem .7rem; font-size: .78rem; }
}
@media (max-width: 380px) {
  .hs-header-actions .hs-header-btn-register-text { display: none; }
  .hs-header-actions .hs-header-btn-register { padding: .5rem .6rem; }
}
.hs-public-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 1rem 1.5rem;
  max-width: 1200px;
  margin: 0 auto;
}
.hs-logo {
  font-weight: 700;
  font-size: 1.125rem;
  letter-spacing: -0.02em;
  display: flex;
  align-items: center;
  gap: .5rem;
}
.hs-logo-mark {
  width: 36px; height: 36px;
  border-radius: 10px;
  background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 100%);
  display: grid; place-items: center;
  color: #fff; font-size: .85rem;
  overflow: hidden;
  box-shadow: 0 4px 14px rgba(15, 23, 42, .18);
}
.hs-brand-mark { display: block; width: 100%; height: 100%; }
.hs-brand-mark svg { display: block; width: 100%; height: 100%; }
.hp-sidebar-brand-mark .hs-brand-mark,
.hs-footer-logo .hs-brand-mark { width: 100%; height: 100%; }
.hs-nav { display: flex; align-items: center; gap: .75rem; flex-wrap: wrap; }
.hs-btn {
  display: inline-flex; align-items: center; justify-content: center; gap: .4rem;
  padding: .65rem 1.15rem;
  border-radius: 999px;
  font-weight: 600; font-size: .9rem;
  border: none; cursor: pointer;
  transition: transform .15s, box-shadow .15s;
}
.hs-btn:active { transform: scale(.98); }
.hs-btn-primary {
  background: linear-gradient(135deg, var(--hs-btn-from, var(--hs-accent)), var(--hs-btn-to, var(--hs-accent-2)));
  color: #fff;
  box-shadow: 0 8px 22px color-mix(in srgb, var(--hs-btn-from, var(--hs-accent)) 32%, transparent);
}
.hs-btn-primary:hover {
  text-decoration: none;
  color: #fff;
  filter: brightness(1.05);
  box-shadow: 0 10px 26px color-mix(in srgb, var(--hs-btn-from, var(--hs-accent)) 40%, transparent);
}
.hs-btn-ghost {
  background: var(--hs-surface);
  color: var(--hs-text);
  border: 1px solid var(--hs-border);
}
.hs-btn-sm { padding: .5rem .85rem; font-size: .82rem; }
.hs-hero {
  max-width: 1200px;
  margin: 0 auto;
  padding: 3rem 1.5rem 4rem;
  display: grid;
  gap: 2.5rem;
  position: relative;
  grid-template-columns: 1fr;
  align-items: start;
}
@media (min-width: 900px) {
  .hs-hero {
    grid-template-columns: 1.15fr .85fr;
    align-items: center;
  }
}
/* Site theme — pleasant emerald green (Solaskinner) */
.hs-theme-fire {
  --hs-accent: #059669;
  --hs-accent-2: #34d399;
  --hs-accent-soft: #ecfdf5;
  --hs-btn-from: #10b981;
  --hs-btn-to: #047857;
  --hs-success: #059669;
}
.hs-hero--fire {
  max-width: 1200px;
  margin: 0 auto;
  padding: 2.25rem 1.5rem 3rem;
  display: flex;
  flex-direction: column;
  gap: 1.75rem;
  position: relative;
  overflow: visible;
}
.hs-hero--fire .hs-hero-main {
  display: grid;
  gap: 1.75rem;
  align-items: center;
  position: relative;
  overflow: visible;
}
/* Hero sun nucleus — side panel + server strip + entrance */
.hs-hero-sun-side {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: min(100%, 13.5rem);
  margin: 0 auto;
  isolation: isolate;
  animation: hs-hero-sun-enter .9s cubic-bezier(.22, 1, .36, 1) both;
}
.hs-hero-sun-side::before {
  content: '';
  position: absolute;
  inset: -18% -12%;
  border-radius: 50%;
  background: radial-gradient(circle at 42% 44%, rgba(251, 191, 36, .55), rgba(249, 115, 22, .18) 48%, transparent 72%);
  filter: blur(18px);
  z-index: 0;
  animation: hs-nucleus-ambient 5s ease-in-out infinite;
  pointer-events: none;
}
.hs-hero-sun-side::after {
  content: '';
  position: absolute;
  inset: 8% 10%;
  border-radius: 50%;
  border: 1px solid rgba(251, 191, 36, .22);
  box-shadow: 0 0 40px rgba(251, 191, 36, .12);
  z-index: 0;
  animation: hs-nucleus-orbit-ring 24s linear infinite;
  pointer-events: none;
}
.hs-hero-sun-side .hs-nucleus-svg {
  position: relative;
  z-index: 1;
  width: 100%;
  max-width: 13.5rem;
  height: auto;
  display: block;
  filter:
    drop-shadow(0 18px 36px rgba(234, 88, 12, .28))
    drop-shadow(0 0 28px rgba(251, 191, 36, .35));
}
.hs-nucleus-corona-spin {
  transform-origin: 64px 64px;
  animation: hs-nucleus-corona-spin 48s linear infinite;
}
.hs-nucleus-rays {
  animation: hs-nucleus-rays-pulse 3.6s ease-in-out infinite;
}
.hs-nucleus-flare {
  transform-origin: 64px 64px;
  animation: hs-nucleus-flare-breathe 4.2s ease-in-out infinite;
}
.hs-nucleus-core {
  transform-origin: 64px 64px;
  animation: hs-nucleus-core-pulse 2.8s ease-in-out infinite;
}
.hs-nucleus-core-shine {
  animation: hs-nucleus-shine-drift 5s ease-in-out infinite;
}
.hs-nucleus-server {
  animation: hs-nucleus-server-float 6s ease-in-out infinite;
}
.hs-nucleus-led--1 { animation: hs-nucleus-led-blink 1.4s ease-in-out infinite; }
.hs-nucleus-led--2 { animation: hs-nucleus-led-blink 1.4s ease-in-out .45s infinite; }
.hs-nucleus-led--3 { animation: hs-nucleus-led-blink 1.4s ease-in-out .9s infinite; }
.hs-nucleus-volt {
  fill: none;
  stroke-dasharray: 14 86;
  stroke-dashoffset: 72;
  opacity: 0;
  animation: hs-nucleus-volt-travel 2.1s ease-in-out infinite;
}
.hs-nucleus-volt--a { animation-delay: 0s; }
.hs-nucleus-volt--b { animation-delay: .55s; }
.hs-nucleus-volt--c { animation-delay: 1.1s; }
@keyframes hs-hero-sun-enter {
  from { opacity: 0; transform: translateX(-1.25rem) scale(.94); }
  to { opacity: 1; transform: none; }
}
@keyframes hs-nucleus-ambient {
  0%, 100% { opacity: .75; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.08); }
}
@keyframes hs-nucleus-orbit-ring {
  to { transform: rotate(360deg); }
}
@keyframes hs-nucleus-corona-spin {
  to { transform: rotate(360deg); }
}
@keyframes hs-nucleus-rays-pulse {
  0%, 100% { opacity: .72; }
  50% { opacity: 1; }
}
@keyframes hs-nucleus-flare-breathe {
  0%, 100% { opacity: .38; transform: scale(1); }
  50% { opacity: .62; transform: scale(1.1); }
}
@keyframes hs-nucleus-core-pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}
@keyframes hs-nucleus-shine-drift {
  0%, 100% { transform: translate(0, 0); opacity: .35; }
  50% { transform: translate(2px, 2px); opacity: .55; }
}
@keyframes hs-nucleus-server-float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-1.5px); }
}
@keyframes hs-nucleus-led-blink {
  0%, 68%, 100% { opacity: .45; filter: none; }
  82% { opacity: 1; filter: drop-shadow(0 0 4px currentColor); }
}
@keyframes hs-nucleus-volt-travel {
  0% { stroke-dashoffset: 72; opacity: 0; }
  12% { opacity: 1; }
  88% { opacity: 1; }
  100% { stroke-dashoffset: 0; opacity: 0; }
}
.hs-eco-nucleus-wrap {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}
.hs-eco-nucleus-wrap .hs-nucleus-svg {
  width: 100%;
  height: 100%;
  filter: drop-shadow(0 0 18px rgba(251, 191, 36, .45));
}
.hs-hero-server-strip {
  display: inline-flex;
  align-items: center;
  gap: .45rem;
  margin: 0 0 1rem;
  padding: .42rem .85rem .42rem .65rem;
  border-radius: 8px;
  font-size: .72rem;
  font-weight: 600;
  letter-spacing: .04em;
  color: #475569;
  background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
  border: 1px solid rgba(148, 163, 184, .35);
  box-shadow: 0 4px 14px rgba(15, 23, 42, .06), inset 0 1px 0 rgba(255, 255, 255, .85);
  animation: hs-hero-strip-enter .75s cubic-bezier(.22, 1, .36, 1) .12s both;
}
.hs-hero-server-strip-text {
  font-variant-numeric: tabular-nums;
}
.hs-srv-led {
  width: .42rem;
  height: .42rem;
  border-radius: 50%;
  flex-shrink: 0;
  box-shadow: inset 0 1px 2px rgba(0, 0, 0, .15);
}
.hs-srv-led--ok {
  background: #34d399;
  animation: hs-srv-led-pulse 2.2s ease-in-out infinite;
}
.hs-srv-led--act {
  background: #22d3ee;
  animation: hs-srv-led-pulse 1.6s ease-in-out .35s infinite;
}
.hs-srv-led--net {
  background: #fbbf24;
  animation: hs-srv-led-pulse 2.8s ease-in-out .7s infinite;
}
@keyframes hs-hero-strip-enter {
  from { opacity: 0; transform: translateY(-.5rem); }
  to { opacity: 1; transform: none; }
}
@keyframes hs-srv-led-pulse {
  0%, 72%, 100% { opacity: .55; box-shadow: inset 0 1px 2px rgba(0, 0, 0, .15); }
  86% { opacity: 1; box-shadow: 0 0 8px currentColor, inset 0 1px 2px rgba(0, 0, 0, .1); }
}
.hs-hero--fire .hs-hero-copy {
  animation: hs-hero-copy-enter .85s cubic-bezier(.22, 1, .36, 1) .18s both;
}
.hs-hero--fire .hs-hero-copy h1 { animation: hs-hero-item-enter .8s cubic-bezier(.22, 1, .36, 1) .28s both; }
.hs-hero--fire .hs-hero-copy > p { animation: hs-hero-item-enter .8s cubic-bezier(.22, 1, .36, 1) .38s both; }
.hs-hero--fire .hs-hero-actions { animation: hs-hero-item-enter .8s cubic-bezier(.22, 1, .36, 1) .48s both; }
.hs-hero--fire .hs-hero-mini-stats { animation: hs-hero-item-enter .8s cubic-bezier(.22, 1, .36, 1) .58s both; }
@keyframes hs-hero-copy-enter {
  from { opacity: 0; }
  to { opacity: 1; }
}
@keyframes hs-hero-item-enter {
  from { opacity: 0; transform: translateY(.65rem); }
  to { opacity: 1; transform: none; }
}
.hs-hero-panel-combo .hs-hero-frame-chrome {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  z-index: 5;
  display: flex;
  align-items: center;
  gap: .55rem;
  padding: .5rem .85rem;
  border-radius: 20px 20px 0 0;
  background: linear-gradient(180deg, rgba(15, 23, 42, .94) 0%, rgba(15, 23, 42, .78) 100%);
  border-bottom: 1px solid rgba(255, 255, 255, .08);
  pointer-events: none;
  animation: hs-frame-chrome-enter .7s cubic-bezier(.22, 1, .36, 1) .35s both;
}
.hs-frame-dot {
  width: .55rem;
  height: .55rem;
  border-radius: 50%;
  flex-shrink: 0;
}
.hs-frame-dot--r { background: #f87171; }
.hs-frame-dot--y { background: #fbbf24; }
.hs-frame-dot--g { background: #34d399; }
.hs-frame-title {
  flex: 1;
  font-size: .72rem;
  font-weight: 600;
  color: rgba(226, 232, 240, .88);
  letter-spacing: .02em;
}
.hs-frame-status {
  display: inline-flex;
  align-items: center;
  gap: .35rem;
  font-size: .65rem;
  font-weight: 700;
  letter-spacing: .08em;
  text-transform: uppercase;
  color: #34d399;
}
.hs-frame-live {
  font-size: .42rem;
  animation: hs-frame-live-blink 1.8s ease-in-out infinite;
}
@keyframes hs-frame-chrome-enter {
  from { opacity: 0; transform: translateY(-.35rem); }
  to { opacity: 1; transform: none; }
}
@keyframes hs-frame-live-blink {
  0%, 70%, 100% { opacity: .45; }
  85% { opacity: 1; }
}
.hs-hero-panel-combo .hs-hero-visual-frame {
  padding-top: 2.15rem;
}
.hs-hero-panel-row {
  animation: hs-hero-panel-enter .9s cubic-bezier(.22, 1, .36, 1) .42s both;
}
@keyframes hs-hero-panel-enter {
  from { opacity: 0; transform: translateY(1rem); }
  to { opacity: 1; transform: none; }
}
/* Domain search card — animated typewriter (green branded hero) */
.hs-hero--branded .hs-hero-card {
  animation: hs-hero-card-enter .85s cubic-bezier(.22, 1, .36, 1) .06s both;
  position: relative;
  z-index: 3;
}
@keyframes hs-hero-card-enter {
  from { opacity: 0; transform: translateY(.7rem); }
  to { opacity: 1; transform: none; }
}
.hs-hero--branded .hs-hero-tld-chip {
  animation: hs-hero-tld-chip-in .55s cubic-bezier(.22, 1, .36, 1) both;
}
.hs-hero--branded .hs-hero-tld-chip:nth-child(1) { animation-delay: .14s; }
.hs-hero--branded .hs-hero-tld-chip:nth-child(2) { animation-delay: .2s; }
.hs-hero--branded .hs-hero-tld-chip:nth-child(3) { animation-delay: .26s; }
.hs-hero--branded .hs-hero-tld-chip:nth-child(4) { animation-delay: .32s; }
.hs-hero--branded .hs-hero-tld-chip:nth-child(5) { animation-delay: .38s; }
.hs-hero--branded .hs-hero-tld-chip:nth-child(n+6) { animation-delay: .44s; }
@keyframes hs-hero-tld-chip-in {
  from { opacity: 0; transform: translateY(.35rem) scale(.96); }
  to { opacity: 1; transform: none; }
}
.hs-hero--branded .hs-domain-typewriter-wrap {
  position: relative;
  isolation: isolate;
}
.hs-hero--branded .hs-domain-typewriter-demo {
  z-index: 5;
  animation: hs-search-demo-in .5s cubic-bezier(.22, 1, .36, 1) .22s both;
}
.hs-hero--branded .hs-domain-typewriter-wrap input {
  z-index: 4;
  position: relative;
}
.hs-hero--branded .hs-domain-typewriter-wrap:not(.is-active):not(.has-value) input {
  border-color: color-mix(in srgb, var(--hs-accent) 28%, var(--hs-border));
  box-shadow: 0 0 0 0 rgba(5, 150, 105, 0);
  animation: hs-search-field-pulse 2.8s ease-in-out infinite;
}
.hs-hero--branded .hs-domain-typewriter-wrap.is-active input,
.hs-hero--branded .hs-domain-typewriter-wrap.has-value input {
  animation: none;
  border-color: var(--hs-border);
  box-shadow: none;
}
.hs-hero--branded .hs-domain-typewriter-wrap.is-active input:focus,
.hs-hero--branded .hs-domain-typewriter-wrap.has-value input:focus {
  border-color: var(--hs-accent);
  box-shadow: 0 0 0 3px rgba(5, 150, 105, .15);
}
@keyframes hs-search-demo-in {
  from { opacity: 0; }
  to { opacity: 1; }
}
@keyframes hs-search-field-pulse {
  0%, 100% {
    border-color: color-mix(in srgb, var(--hs-accent) 22%, var(--hs-border));
    box-shadow: 0 0 0 0 rgba(5, 150, 105, 0);
  }
  50% {
    border-color: color-mix(in srgb, var(--hs-accent) 42%, var(--hs-border));
    box-shadow: 0 0 0 3px rgba(5, 150, 105, .1);
  }
}
.hs-hero--branded [data-hs-domain-btn] {
  transition: transform .2s ease, box-shadow .2s ease;
}
.hs-hero--branded .hs-domain-typewriter-wrap:not(.is-active):not(.has-value) ~ [data-hs-domain-btn] {
  animation: hs-search-btn-glow 2.8s ease-in-out infinite;
}
.hs-hero--branded .hs-domain-typewriter-wrap.is-active ~ [data-hs-domain-btn],
.hs-hero--branded .hs-domain-typewriter-wrap.has-value ~ [data-hs-domain-btn] {
  animation: none;
}
@keyframes hs-search-btn-glow {
  0%, 100% { box-shadow: 0 4px 14px rgba(5, 150, 105, .2); }
  50% { box-shadow: 0 6px 22px rgba(5, 150, 105, .34); }
}
.hs-hero-showcase {
  max-width: 1200px;
  margin: -1rem auto 2.5rem;
  padding: 0 1.5rem;
}
.hs-hero-showcase-inner {
  max-width: 52rem;
  margin: 0 auto;
}
.hs-hero-showcase .hs-hero-visual-frame {
  border: 1px solid rgba(5, 150, 105, .22);
  box-shadow:
    0 24px 60px rgba(5, 150, 105, .12),
    0 0 0 1px rgba(255, 255, 255, .6) inset;
}
.hs-hero-showcase .hs-hero-visual-glow {
  background: radial-gradient(circle, rgba(16, 185, 129, .38), transparent 68%);
}
.hs-hero-panel-row {
  width: 100%;
  min-width: 0;
}
.hs-hero-panel-combo {
  position: relative;
  width: 100%;
}
.hs-hero-panel-row .hs-hero-visual-stack {
  width: 100%;
  max-width: 100%;
}
@media (min-width: 900px) {
  .hs-hero--fire .hs-hero-main {
    grid-template-columns: minmax(10.5rem, 13.5rem) minmax(0, 1fr);
    gap: 2.25rem;
    overflow: visible;
    align-items: center;
  }
  .hs-hero-sun-side {
    width: 100%;
    max-width: 13.5rem;
    margin: 0;
    justify-self: start;
  }
  .hs-hero-sun-side .hs-nucleus-svg {
    max-width: 13.5rem;
  }
  .hs-hero-panel-row {
    margin-top: 1.25rem;
  }
  .hs-hero-panel-combo {
    overflow: visible;
  }
  .hs-hero-panel-row .hs-hero-visual-frame {
    position: relative;
    z-index: 1;
  }
  .hs-hero-eco-stage--on-shot {
    position: absolute;
    right: -.5rem;
    top: -.85rem;
    transform: none;
    width: min(40%, 21rem);
    max-width: 21rem;
    padding: 2rem 0 1rem;
    z-index: 4;
    pointer-events: none;
  }
  .hs-hero-eco-stage--on-shot .hs-eco-planet {
    pointer-events: auto;
  }
  .hs-hero-panel-combo::after {
    content: '';
    position: absolute;
    right: 0;
    top: 0;
    width: 48%;
    height: 54%;
    border-radius: 0 20px 0 0;
    background: linear-gradient(135deg, transparent 0%, rgba(255, 247, 237, .65) 42%, rgba(255, 247, 237, .92) 100%);
    pointer-events: none;
    z-index: 2;
  }
}
.hs-hero-pill {
  display: inline-flex;
  align-items: center;
  gap: .45rem;
  margin: 0 0 .85rem;
  padding: .35rem .85rem .35rem .55rem;
  border-radius: 999px;
  font-size: .78rem;
  font-weight: 600;
  color: #9a3412;
  background: #fff7ed;
  border: 1px solid rgba(234, 88, 12, .22);
}
.hs-hero-pill-dot {
  width: .5rem;
  height: .5rem;
  border-radius: 50%;
  background: #059669;
  box-shadow: 0 0 0 4px rgba(5, 150, 105, .2);
  animation: hs-fire-pulse 2s ease-in-out infinite;
}
@keyframes hs-fire-pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: .75; transform: scale(1.15); }
}
.hs-theme-fire .hs-hero-kicker {
  color: #047857;
  background: #ecfdf5;
  border: 1px solid rgba(5, 150, 105, .22);
}
.hs-theme-fire .hs-hero-kicker i { color: #059669; }
.hs-theme-fire .hs-gradient-text {
  background: linear-gradient(120deg, #34d399, #10b981 40%, #059669 75%, #047857);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
}
/* Emerald CTAs */
.hs-theme-fire .hs-btn-primary {
  background: linear-gradient(145deg, #34d399 0%, #10b981 42%, #059669 100%);
  color: #fff;
  border: 1px solid rgba(4, 120, 87, .25);
  box-shadow: 0 8px 22px rgba(5, 150, 105, .28);
}
.hs-theme-fire .hs-btn-primary:hover {
  background: linear-gradient(145deg, #6ee7b7 0%, #34d399 40%, #10b981 100%);
  color: #fff;
  filter: none;
  box-shadow: 0 12px 28px rgba(5, 150, 105, .36);
}
.hs-theme-fire .hs-btn-ghost {
  border-color: rgba(5, 150, 105, .28);
  color: #047857;
  background: #fff;
}
.hs-theme-fire .hs-btn-ghost:hover {
  border-color: #10b981;
  background: #ecfdf5;
  color: #065f46;
  text-decoration: none;
}
.hs-theme-fire .hs-plan-cta.hs-btn-primary {
  background: linear-gradient(145deg, #34d399 0%, #10b981 45%, #059669 100%);
}
.hs-hero-mini-stats {
  display: flex;
  flex-wrap: wrap;
  gap: 1.25rem 1.75rem;
  margin-top: 1.35rem;
  padding-top: 1.1rem;
  border-top: 1px solid var(--hs-border);
}
.hs-hero-mini-stat strong {
  display: block;
  font-size: 1.15rem;
  font-weight: 800;
  color: var(--hs-accent);
  letter-spacing: -0.02em;
}
.hs-hero-mini-stat span {
  display: block;
  font-size: .78rem;
  color: var(--hs-muted);
  margin-top: .1rem;
}
.hs-hero-visual { position: relative; min-width: 0; overflow: visible; }
.hs-hero-visual-stack {
  display: flex; flex-direction: column; align-items: center; gap: 1.35rem; width: 100%;
  overflow: visible;
  position: relative;
}
/* Hero CMS planets — light orbit stage beside copy */
.hs-hero-eco-stage {
  width: min(100%, 22rem);
  max-width: 22rem;
  margin: 0 auto;
  padding: 2.75rem .5rem 2rem;
  position: relative;
  z-index: 1;
}
.hs-hero-eco-hub-wrap {
  width: 100%;
  margin: 0 auto;
  padding: 0;
  overflow: visible;
  position: relative;
  animation: hs-eco-stage-float 8s ease-in-out infinite;
}
@keyframes hs-eco-stage-float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-7px); }
}
.hs-eco-hub {
  position: relative;
  width: 100%;
  aspect-ratio: 1;
  overflow: visible;
  isolation: isolate;
  transform-style: preserve-3d;
}
.hs-eco-rings {
  position: absolute;
  inset: 0;
  pointer-events: none;
  z-index: 1;
}
.hs-eco-ring {
  position: absolute;
  top: 50%;
  left: 50%;
  border-radius: 50%;
  transform: translate(-50%, -50%);
  border: 1px dashed rgba(234, 88, 12, .14);
}
.hs-eco-ring--inner {
  width: 50%;
  height: 50%;
  border-color: rgba(52, 211, 153, .22);
  animation: hs-eco-ring-drift 72s linear infinite reverse;
}
.hs-eco-ring--mid {
  width: 72%;
  height: 72%;
  border-color: rgba(148, 163, 184, .2);
  animation: hs-eco-ring-drift 96s linear infinite;
}
.hs-eco-ring--outer {
  width: 94%;
  height: 94%;
  border-color: rgba(167, 139, 250, .18);
  animation: hs-eco-ring-drift 120s linear infinite reverse;
}
@keyframes hs-eco-ring-drift {
  to { transform: translate(-50%, -50%) rotate(360deg); }
}
.hs-eco-mesh-svg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  z-index: 2;
  pointer-events: none;
  overflow: visible;
}
.hs-eco-mesh-line {
  stroke: rgba(148, 163, 184, .28);
  stroke-width: .4;
  vector-effect: non-scaling-stroke;
}
.hs-eco-mesh-pulse {
  stroke: #22d3ee;
  stroke-width: .65;
  stroke-linecap: round;
  stroke-dasharray: 7 93;
  vector-effect: non-scaling-stroke;
  filter: drop-shadow(0 0 3px rgba(34, 211, 238, .75));
  animation: hs-eco-mesh-flow 1.75s linear infinite;
}
.hs-eco-mesh-pulse--green {
  stroke: #34d399;
  filter: drop-shadow(0 0 3px rgba(52, 211, 153, .75));
}
.hs-eco-mesh-pulse--violet {
  stroke: #a78bfa;
  filter: drop-shadow(0 0 3px rgba(167, 139, 250, .75));
}
@keyframes hs-eco-mesh-flow {
  from { stroke-dashoffset: 100; opacity: .25; }
  45% { opacity: 1; }
  to { stroke-dashoffset: 0; opacity: .25; }
}
.hs-eco-fiber-spoke {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 1;
  overflow: visible;
}
.hs-eco-fiber-base {
  stroke: rgba(148, 163, 184, .22);
  stroke-width: 1.2;
  vector-effect: non-scaling-stroke;
}
.hs-eco-fiber-pulse {
  stroke-width: 1.6;
  stroke-linecap: round;
  vector-effect: non-scaling-stroke;
  filter: drop-shadow(0 0 4px currentColor);
}
.hs-eco-fiber-pulse--out {
  stroke: #22d3ee;
  stroke-dasharray: 8 92;
  animation: hs-eco-fiber-flow-out 1.5s linear infinite;
  animation-delay: var(--pulse-delay, 0s);
}
.hs-eco-fiber-pulse--in {
  stroke: #f59e0b;
  stroke-dasharray: 6 94;
  animation: hs-eco-fiber-flow-in 2.1s linear infinite;
  animation-delay: calc(var(--pulse-delay, 0s) + .6s);
}
@keyframes hs-eco-fiber-flow-out {
  from { stroke-dashoffset: 100; opacity: .2; }
  40% { opacity: 1; }
  to { stroke-dashoffset: 0; opacity: .2; }
}
@keyframes hs-eco-fiber-flow-in {
  from { stroke-dashoffset: 100; opacity: .15; }
  40% { opacity: .9; }
  to { stroke-dashoffset: 0; opacity: .15; }
}
.hs-eco-orbit {
  position: absolute;
  top: 50%;
  left: 50%;
  border-radius: 50%;
  transform-origin: center center;
  animation: hs-eco-orbit-spin var(--eco-dur, 24s) linear infinite;
  pointer-events: none;
  z-index: 3;
  will-change: transform;
}
.hs-eco-orbit--inner {
  width: 50%;
  height: 50%;
  margin: -25% 0 0 -25%;
}
.hs-eco-orbit--mid {
  width: 72%;
  height: 72%;
  margin: -36% 0 0 -36%;
}
.hs-eco-orbit--outer {
  width: 94%;
  height: 94%;
  margin: -47% 0 0 -47%;
}
@keyframes hs-eco-orbit-spin {
  from { transform: rotate(var(--eco-phase, 0deg)); }
  to { transform: rotate(calc(var(--eco-phase, 0deg) + 360deg)); }
}
.hs-eco-planet {
  position: absolute;
  top: -2rem;
  left: calc(50% - 2rem);
  width: 4rem;
  height: 4rem;
  pointer-events: auto;
  text-decoration: none;
  z-index: 2;
  animation: hs-eco-planet-tug 2.8s ease-in-out infinite;
  animation-delay: var(--tug-delay, 0s);
}
@keyframes hs-eco-planet-tug {
  0%, 100% { transform: scale(1); }
  8% { transform: scale(1.1); }
  16% { transform: scale(1); }
  24% { transform: scale(1.05); }
  32% { transform: scale(1); }
}
.hs-eco-planet-inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: .2rem;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  font-size: .58rem;
  font-weight: 700;
  letter-spacing: .02em;
  line-height: 1.15;
  text-align: center;
  border: 1px solid rgba(148, 163, 184, .32);
  background:
    radial-gradient(circle at 32% 28%, rgba(255, 255, 255, .98), transparent 42%),
    radial-gradient(circle at 35% 30%, #f8fafc, #e2e8f0);
  box-shadow: 0 4px 16px rgba(15, 23, 42, .08), 0 0 14px color-mix(in srgb, currentColor 35%, transparent);
  animation: hs-eco-planet-upright var(--eco-dur, 24s) linear infinite;
  transition: transform .3s cubic-bezier(.34, 1.4, .64, 1), box-shadow .3s ease, border-color .3s ease;
  will-change: transform;
}
.hs-eco-planet-inner span {
  max-width: 4.2rem;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
@keyframes hs-eco-planet-upright {
  from { transform: rotate(calc(-1 * var(--eco-phase, 0deg))); }
  to { transform: rotate(calc(-1 * var(--eco-phase, 0deg) - 360deg)); }
}
.hs-eco-orbit:has(.hs-eco-planet:hover) {
  animation-play-state: paused;
  z-index: 8;
}
.hs-eco-planet:hover .hs-eco-planet-inner {
  animation-play-state: paused, paused;
  transform: scale(1.2);
  border-color: rgba(255, 255, 255, .35);
  box-shadow: 0 0 28px currentColor, 0 0 52px currentColor;
}

.hs-eco-planet i { font-size: 1.15rem; }
.hs-eco-planet--amber { color: #fbbf24; }
.hs-eco-planet--sky { color: #38bdf8; }
.hs-eco-planet--teal { color: #2dd4bf; }
.hs-eco-planet--rose { color: #fb7185; }
.hs-eco-planet--cyan { color: #22d3ee; }
.hs-eco-planet--emerald { color: #34d399; }
.hs-eco-planet--violet { color: #a78bfa; }
.hs-eco-planet--orange { color: #fb923c; }
.hs-eco-planet--red { color: #f87171; }
.hs-eco-planet--indigo { color: #818cf8; }
.hs-eco-planet--amber .hs-eco-planet-inner { color: #fbbf24; }
.hs-eco-planet--sky .hs-eco-planet-inner { color: #38bdf8; }
.hs-eco-planet--teal .hs-eco-planet-inner { color: #2dd4bf; }
.hs-eco-planet--rose .hs-eco-planet-inner { color: #fb7185; }
.hs-eco-planet--cyan .hs-eco-planet-inner { color: #22d3ee; }
.hs-eco-planet--emerald .hs-eco-planet-inner { color: #34d399; }
.hs-eco-planet--violet .hs-eco-planet-inner { color: #a78bfa; }
.hs-eco-planet--orange .hs-eco-planet-inner { color: #fb923c; }
.hs-eco-planet--red .hs-eco-planet-inner { color: #f87171; }
.hs-eco-planet--indigo .hs-eco-planet-inner { color: #818cf8; }
.hs-eco-planet--featured .hs-eco-planet-inner {
  border-width: 2px;
  animation: hs-eco-planet-upright var(--eco-dur, 24s) linear infinite, hs-eco-planet-featured-pulse 2.6s ease-in-out infinite;
}
.hs-eco-planet--featured.hs-eco-planet--sky .hs-eco-planet-inner {
  border-color: rgba(56, 189, 248, .7);
  box-shadow: 0 0 22px rgba(56, 189, 248, .55), 0 0 42px rgba(56, 189, 248, .28), inset 0 0 18px rgba(56, 189, 248, .12);
}
.hs-eco-planet--featured.hs-eco-planet--rose .hs-eco-planet-inner {
  border-color: rgba(251, 113, 133, .7);
  box-shadow: 0 0 22px rgba(251, 113, 133, .55), 0 0 42px rgba(251, 113, 133, .28), inset 0 0 18px rgba(251, 113, 133, .12);
}
.hs-eco-planet--featured.hs-eco-planet--violet .hs-eco-planet-inner {
  border-color: rgba(167, 139, 250, .7);
  box-shadow: 0 0 22px rgba(167, 139, 250, .55), 0 0 42px rgba(167, 139, 250, .28), inset 0 0 18px rgba(167, 139, 250, .12);
}
.hs-eco-planet--featured.hs-eco-planet--emerald .hs-eco-planet-inner {
  border-color: rgba(52, 211, 153, .7);
  box-shadow: 0 0 22px rgba(52, 211, 153, .55), 0 0 42px rgba(52, 211, 153, .28), inset 0 0 18px rgba(52, 211, 153, .12);
}
.hs-eco-planet--featured::after {
  content: '';
  position: absolute;
  inset: -6px;
  border-radius: 50%;
  border: 1px solid currentColor;
  opacity: .35;
  animation: hs-eco-planet-featured-ring 2.6s ease-in-out infinite;
  pointer-events: none;
}
@keyframes hs-eco-planet-featured-pulse {
  0%, 100% { filter: brightness(1); }
  50% { filter: brightness(1.3); }
}
@keyframes hs-eco-planet-featured-ring {
  0%, 100% { transform: scale(1); opacity: .35; }
  50% { transform: scale(1.08); opacity: .6; }
}
.hs-eco-planet--featured:hover .hs-eco-planet-inner {
  transform: scale(1.18);
  box-shadow: 0 0 32px currentColor, 0 0 56px currentColor;
}
.hs-eco-hub-core {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 38%;
  height: 38%;
  transform: translate(-50%, -50%);
  z-index: 6;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
  animation: hs-eco-core-pulse 3.2s ease-in-out infinite;
}
.hs-eco-sun-rays,
.hs-eco-sun-flare { display: none; }
@keyframes hs-eco-core-pulse {
  0%, 100% {
    filter: drop-shadow(0 0 20px rgba(251, 191, 36, .4));
    transform: translate(-50%, -50%) scale(1);
  }
  50% {
    filter: drop-shadow(0 0 32px rgba(251, 191, 36, .65));
    transform: translate(-50%, -50%) scale(1.04);
  }
}
.hs-hero-sun-fiber--hero {
  position: relative;
  top: auto;
  right: auto;
  left: auto;
  opacity: 1;
}
.hs-hero-sun-fiber--hero .hs-hero-sun-fiber-art {
  position: relative;
  z-index: 2;
  width: 100%;
  max-width: none;
  filter:
    drop-shadow(0 14px 32px rgba(234, 88, 12, .28))
