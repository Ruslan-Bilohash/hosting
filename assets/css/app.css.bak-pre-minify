.hs-sec-scan-optional .hs-sec-scan-badge { background: #f1f5f9; color: #64748b; }
body.hs-perf-scanning .hs-sec-scan-report { opacity: .55; pointer-events: none; }
body.hs-perf-scanning [data-hs-perf-findings] { opacity: .55; pointer-events: none; }

/* ——— Legal pages (GDPR / NO compliance) ——— */
