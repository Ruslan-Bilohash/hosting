.hs-home-feature h3 { margin: 0 0 .35rem; font-size: 1rem; }
.hs-home-feature p { margin: 0; color: var(--hs-home-muted); font-size: .92rem; line-height: 1.5; }

.hs-home-steps { display: grid; gap: 1rem; grid-template-columns: 1fr; }
