.hs-seo-app-faq-item p{margin:.55rem 0 0;color:var(--hs-muted,#64748b);line-height:1.5}
.hs-seo-hub-grid{display:grid;gap:1rem;grid-template-columns:repeat(auto-fill,minmax(15.5rem,1fr));margin-top:1.75rem}
.hs-seo-hub-card{display:flex;flex-direction:column;gap:.4rem;padding:1.15rem;border:1px solid var(--hs-border,#e2e8f0);border-radius:14px;background:var(--hs-surface,#fff);text-decoration:none;color:inherit;box-shadow:0 6px 20px rgba(15,23,42,.04);transition:border-color .15s,box-shadow .15s}
.hs-seo-hub-card:hover{border-color:#6ee7b7;box-shadow:0 10px 28px rgba(5,150,105,.1)}
.hs-seo-hub-icon{width:2.25rem;height:2.25rem;border-radius:10px;display:inline-flex;align-items:center;justify-content:center;background:#ecfdf5;color:var(--hs-accent,#059669)}
.hs-seo-hub-card-desc{font-size:.88rem;color:var(--hs-muted,#64748b);line-height:1.4;flex:1}
.hs-seo-hub-more{font-size:.82rem;font-weight:700;color:var(--hs-accent,#059669)}
.hs-seo-hub-card-wrap{display:flex;flex-direction:column;gap:.45rem}
.hs-seo-hub-card-wrap .hs-seo-hub-card{flex:1}
.hs-seo-hub-demo{display:inline-flex;align-items:center;justify-content:center;gap:.4rem;padding:.45rem .7rem;border-radius:10px;border:1px solid #a7f3d0;background:#ecfdf5;color:#047857;font-size:.84rem;font-weight:700;text-decoration:none}
.hs-seo-hub-demo:hover{border-color:#34d399;background:#d1fae5;color:#065f46;text-decoration:none}
.hs-seo-app-demo-note{margin:.35rem 0 0;font-size:.9rem;line-height:1.45}
.hs-seo-app-demo-note a{font-weight:600;word-break:break-all}
.hs-seo-related{display:flex;flex-wrap:wrap;gap:.5rem}
.hs-seo-related a{display:inline-flex;padding:.4rem .75rem;border-radius:999px;border:1px solid #d1fae5;background:#f0fdf4;color:#065f46;text-decoration:none;font-size:.86rem;font-weight:600}
.hs-seo-related a:hover{border-color:#34d399;background:#ecfdf5}
@media (max-width:640px){.hs-seo-app-ctas .hs-btn,.hs-seo-app-bottom .hs-btn{width:100%;justify-content:center}}

