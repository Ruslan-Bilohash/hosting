}
.hs-sec-scan-good { border-color: #a7f3d0; background: linear-gradient(135deg, #f0fdf4 0%, #fff 65%); }
.hs-sec-scan-fair { border-color: #fde68a; background: linear-gradient(135deg, #fffbeb 0%, #fff 65%); }
.hs-sec-scan-poor { border-color: #fecaca; background: linear-gradient(135deg, #fef2f2 0%, #fff 65%); }
.hs-sec-scan-head { display: flex; gap: 1rem; align-items: flex-start; flex-wrap: wrap; margin-bottom: 1rem; }
.hs-sec-scan-grade {
  min-width: 4.5rem; text-align: center; padding: .55rem .75rem; border-radius: 12px;
  background: #fff; border: 1px solid var(--hs-border); box-shadow: var(--hs-shadow);
}
.hs-sec-scan-good .hs-sec-scan-grade { border-color: #6ee7b7; }
.hs-sec-scan-fair .hs-sec-scan-grade { border-color: #fcd34d; }
.hs-sec-scan-poor .hs-sec-scan-grade { border-color: #fca5a5; }
.hs-sec-scan-grade-letter { display: block; font-size: 1.75rem; font-weight: 800; line-height: 1; color: var(--hs-accent); }
.hs-sec-scan-grade-score { display: block; font-size: .72rem; color: var(--hs-muted); margin-top: .2rem; }
.hs-sec-scan-title { margin: 0 0 .35rem; font-weight: 700; font-size: .95rem; }
.hs-sec-scan-url { margin: 0 0 .35rem; font-size: .82rem; word-break: break-all; }
.hs-sec-scan-table { width: 100%; border-collapse: collapse; font-size: .82rem; }
.hs-sec-scan-table th, .hs-sec-scan-table td {
  padding: .45rem .55rem; border-bottom: 1px solid var(--hs-border); text-align: left; vertical-align: top;
}
.hs-sec-scan-table th { font-size: .72rem; text-transform: uppercase; letter-spacing: .03em; color: var(--hs-muted); }
.hs-sec-scan-val code { font-size: .76rem; word-break: break-all; }
.hs-sec-scan-badge {
  display: inline-block; font-size: .7rem; font-weight: 700; padding: .15rem .45rem; border-radius: 999px;
}
.hs-sec-scan-ok .hs-sec-scan-badge { background: #ecfdf5; color: #047857; }
.hs-sec-scan-weak .hs-sec-scan-badge { background: #fffbeb; color: #b45309; }
